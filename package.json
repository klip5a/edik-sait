{
  "name": "anastasia-eduard-wedding",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node --env-file=.env --import tsx --watch server/index.ts",
    "build": "tsc -b && vite build && npm run server:build",
    "server:build": "tsc -p tsconfig.server.json",
    "start": "node --env-file=.env server-dist/index.js",
    "password:hash": "tsx server/password.ts",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.10",
    "better-sqlite3": "^12.11.1",
    "hono": "^4.12.30",
    "preact": "^10.29.7",
    "swiper": "^14.0.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@preact/preset-vite": "^2.10.5",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@types/better-sqlite3": "^7.6.13",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
