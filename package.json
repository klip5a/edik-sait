{
  "name": "anastasia-eduard-wedding",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.13.1+sha512.b2fc7683b8a6525414e7d13e1ba28caaddde96bf66ec540bfaeb7e702b81f3e0be4d1f295edf7f9fe0396740a8dce4509c582ddf79891f4543fea32d37645f25",
  "engines": {
    "node": "24.x"
  },
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n client,server -c magenta,cyan \"pnpm dev:client\" \"pnpm dev:server\"",
    "dev:client": "vite",
    "native:rebuild": "pnpm rebuild better-sqlite3",
    "predev:server": "pnpm native:rebuild",
    "dev:server": "node --env-file=.env --import tsx --watch server/index.ts",
    "prestart": "pnpm native:rebuild",
    "build": "tsc -b && vite build && pnpm run server:build",
    "server:build": "tsc -p tsconfig.server.json",
    "start": "node --env-file=.env server-dist/index.js",
    "password:hash": "tsx server/password.ts",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.10",
    "better-sqlite3": "^12.11.1",
    "hono": "^4.12.30",
    "preact": "^10.29.7",
    "swiper": "^14.0.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@preact/preset-vite": "^2.10.5",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@types/better-sqlite3": "^7.6.13",
    "concurrently": "^9.2.1",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
